# ── Secrets / API keys — NEVER commit ────────────────────────────────────────
.env
.env.local
.env.production
.env*.local
src/backend/.env
# Allow the example file
!.env.example
!src/backend/.env.example

# ── Large binary data — keep local, distribute via build-package.bat ─────────
# PDF manuals (222 MB — too large for Git)
data/manuals/
# ChromaDB vector index (regenerated from PDFs at build time)
data/chroma_db/
**/chroma_db/
chroma_db/
# SQLite databases (contain user chat history)
*.db
*.db-shm
*.db-wal
# User-uploaded documents
data/user_documents/
# Knowledge base manifest (regenerated from ChromaDB on each machine)
**/kb_manifest.json

# ── Build artefacts — regenerated, never commit ───────────────────────────────
dist/
build/
*.spec.bak
# PyInstaller
src/backend/dist/
src/backend/build/
dist_scripts/dist/
dist_scripts/build/
# Next.js
.next/
src/frontend/.next/
# npm
node_modules/
src/frontend/node_modules/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
venv/
.venv/
src/backend/venv/

# ── OS / editor files ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
