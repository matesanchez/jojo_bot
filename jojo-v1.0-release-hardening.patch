+
+    # Bind to localhost by default — Jojo Bot is a local-only tool and should
+    # never be reachable from the network.  Set JOJO_DEV_LAN=1 to opt into
+    # 0.0.0.0 binding during development (e.g. testing from another device on
+    # the same LAN); production builds always stay on 127.0.0.1.
+    if not settings.is_production and _os.getenv("JOJO_DEV_LAN") == "1":
+        host = "0.0.0.0"
+    else:
+        host = "127.0.0.1"
+
+    if getattr(_sys, "frozen", False):
+        # FROZEN EXE (PyInstaller):  Pass the app object directly.
+        # The import-string form "main:app" fails because PyInstaller stores
+        # the entry script as __main__, not "main", so uvicorn's
+        # importlib.import_module("main") raises ImportError and the backend
+        # silently exits.
+        uvicorn.run(app, host=host, port=8000)
+    else:
+        # DEVELOPMENT:  Use import-string so uvicorn can reload on file changes.
+        uvicorn.run(
+            "main:app",
+            host=host,
+            port=8000,
+            reload=True,
+        )
